{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "S3EC2ReadWriteAccess",
            "Effect": "Allow",
            "Action": [
                "s3:GetObject",
                "s3:PutObject",
                "s3:ListBucket",
                "s3:DeleteObject"
            ],
            "Resource": [
                "arn:aws:s3:::${s3_bucket_name}",
                "arn:aws:s3:::${s3_bucket_name}/*"
            ]
        }
    ]
}